{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "LokadReplica\\Code": "Debug",
      "LokadReplica\\Code.OrderWorkflowService": "Debug",
      "LokadReplica\\Code.ProjectionRefreshService": "Debug",
      "LokadReplica\\Code.HttpClientDiagnostics": "Information",
      "System.Net.Http.HttpClient": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Replica": {
    "EnvironmentName": "Development",
    "Region": "eu-west",
    "NodeName": "replica-a03",
    "ProjectionRefreshIntervalSeconds": 15,
    "ProjectionSnapshotRetentionHours": 48,
    "ProjectionLagWarningMilliseconds": 1200,
    "MaxProjectionLagMilliseconds": 2500,
    "CheckpointReplayWindowMinutes": 20
  },
  "HttpClient": {
    "BaseAddress": "https://replica.dev.lokad.internal",
    "SendAsyncTimeoutSeconds": 30,
    "ProjectionWarmupTimeoutSeconds": 20,
    "MaxRetryCount": 4,
    "RetryBackoffMilliseconds": [
      100,
      250,
      500,
      1000
    ],
    "EmitTimingHeaders": true,
    "CaptureDiagnosticSamples": true
  },
  "Workflow": {
    "EnableProjectionWarmup": true,
    "EnableGeneratedBindings": true,
    "EnableCheckpointBackfill": false,
    "EnableReplicaDiffLogging": true,
    "AllowedOrderStates": [
      "Created",
      "Scheduled",
      "Accepted",
      "Rejected",
      "Packed",
      "Shipped"
    ]
  },
  "Diagnostics": {
    "CaptureProjectionSamples": true,
    "CaptureRequestPayloads": false,
    "RetainRecentRequests": 128,
    "RetainProjectionSnapshots": 32,
    "RetainWorkflowCheckpoints": 512,
    "RetainReplicaDiffs": 24
  },
  "Projection": {
    "WarmupShardCount": 4,
    "HistoryWindowHours": 24,
    "SnapshotWriterBatchSize": 256,
    "SnapshotReaderPageSize": 512
  }
}

